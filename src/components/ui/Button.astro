---
interface Props {
  href?: string;
  variant?: "primary" | "outline" | "ghost" | "outline-light";
  type?: "button" | "submit" | "reset";
  target?: string;
  rel?: string;
  ariaLabel?: string;
  class?: string;
}

const {
  href,
  variant = "primary",
  type = "button",
  target,
  rel,
  ariaLabel,
  class: className = ""
} = Astro.props;

const classes = `btn btn--${variant} ${className}`.trim();

const safeRel = target === "_blank"
  ? rel ?? "noreferrer"
  : rel;
---

{
  href ? (
    <a
      href={href}
      class={classes}
      target={target}
      rel={safeRel}
      aria-label={ariaLabel}
    >
      <slot />
    </a>
  ) : (
    <button
      type={type}
      class={classes}
      aria-label={ariaLabel}
    >
      <slot />
    </button>
  )
}