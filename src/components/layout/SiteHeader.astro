---
const navItems = [
  { label: "Home", href: "/" },
  {
    label: "Ear Care",
    href: "/services/ear-care",
    children: [
      { label: "Portsmouth", href: "/services/ear-care/portsmouth" },
      { label: "Southampton", href: "/services/ear-care/southampton" }
    ]
  },
  { label: "About", href: "/about" },
  { label: "Blog", href: "/blog" },
  { label: "Contact", href: "/contact" }
];
---


  <div class="header-topbar">
        <div class="container">
            <div class="header-topbar__item">
                <i class="fa-sharp fa-thin fa-envelope" aria-hidden="true"></i>
                <a href="mailto:reception@coremedica.co.uk">reception@coremedica.co.uk</a>
            </div>
            <div class="header-topbar__item">
                <i class="fa-sharp fa-thin fa-phone"></i>
                <a href="tel:07777100716">07777 100716</a>
            </div>
        </div>
    </div>
<header class="site-header" id="siteHeader" role="banner">
    <div class="container">
      <a class="site-header__logo" href="/" aria-label="Promedico Wellness Group home">
        <img src="/images/ProMedico-Logo-text.webp" alt="Promedico Wellness Group" />
      </a>

      <button
        class="nav-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="site-navigation"
        aria-label="Toggle navigation"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>

      <nav class="site-nav" id="site-navigation" aria-label="Primary">
        <ul class="site-nav__list">
          <li class="site-nav__item"><a class="site-nav__link" href="/">Home</a></li>

          <li class="site-nav__item site-nav__item--has-children">
            <button
              class="site-nav__link site-nav__link--button"
              type="button"
              aria-expanded="false"
              aria-controls="ear-care-submenu"
            >
              Ear Care
            </button>
            <ul class="site-nav__submenu" id="ear-care-submenu">
              <li><a href="/services/ear-care/portsmouth">Portsmouth</a></li>
              <li><a href="/services/ear-care/southampton">Southampton</a></li>
            </ul>
          </li>

          <li class="site-nav__item"><a class="site-nav__link" href="/about">About</a></li>
          <li class="site-nav__item"><a class="site-nav__link" href="/blog">Blog</a></li>
          <li class="site-nav__item"><a class="site-nav__link" href="/contact">Contact</a></li>
        </ul>
      </nav>
      <div class="site-header__cta">
                <a href="https://promedico-ear-clinic.uk2.cliniko.com/bookings?business_id=1799806171821907984" target="_blank" class="site-header__cta-link">Book Online</a>
            </div>
    </div>

  <div class="nav-overlay" hidden></div>
</header>

<script>
  const header = document.querySelector(".site-header");
  const toggle = header?.querySelector(".nav-toggle");
  const nav = header?.querySelector(".site-nav");
  const overlay = header?.querySelector(".nav-overlay");
  const submenuButton = header?.querySelector(".site-nav__link--button");
  const submenu = header?.querySelector("#ear-care-submenu");

  const closeMenu = () => {
    toggle?.classList.remove("is-open");
    nav?.classList.remove("is-open");
    overlay?.classList.remove("is-visible");
    overlay?.setAttribute("hidden", "");
    toggle?.setAttribute("aria-expanded", "false");
  };

  toggle?.addEventListener("click", () => {
    const isOpen = nav?.classList.toggle("is-open");
    toggle.classList.toggle("is-open");
    toggle.setAttribute("aria-expanded", String(isOpen));
    overlay?.classList.toggle("is-visible", !!isOpen);

    if (isOpen) {
      overlay?.removeAttribute("hidden");
    } else {
      overlay?.setAttribute("hidden", "");
    }
  });

  overlay?.addEventListener("click", closeMenu);

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeMenu();
      submenuButton?.setAttribute("aria-expanded", "false");
      submenu?.classList.remove("is-open");
    }
  });

  submenuButton?.addEventListener("click", () => {
    const expanded = submenuButton.getAttribute("aria-expanded") === "true";
    submenuButton.setAttribute("aria-expanded", String(!expanded));
    submenu?.classList.toggle("is-open", !expanded);
  });
</script>